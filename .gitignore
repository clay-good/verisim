# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
# Root-anchored so they only ignore the build *output* dirs, not the src/verisim/dist package
# (SPEC-7's distributed world). An un-anchored `dist/` would hide that package from git + the wheel.
/build/
/dist/
.venv/
venv/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Claude
.mcp.json
.claude/settings.json
.claude/skills/
.claude/scheduled_tasks.lock

# Run-records: regenerable from configs + seeds (SPEC-2 §10, §12)
/runs/*
!/runs/.gitkeep

# De-fanged codebase fixtures: Verisim-owned scratch copies of real repos (the prototype's
# subject under test). Regenerable via verisim.fixture.materialize; never committed.
/.verisim-fixtures/

# OS
.DS_Store

# openlore analysis artifacts (regenerable from `openlore analyze`)
.openlore/
ARCHITECTURE.md
